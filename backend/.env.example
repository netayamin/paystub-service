# Database (local dev: localhost; production: set to your RDS URL)
DATABASE_URL=postgresql://paystub:paystub@localhost:5432/paystub

# OpenAI (required for /chat AI agent)
OPENAI_API_KEY=

# Resy: get from browser (resy.com → Network tab → api.resy.com requests)
# Authorization header: ResyAPI api_key="..."  → RESY_API_KEY
# x-resy-auth-token header → RESY_AUTH_TOKEN
RESY_API_KEY=
RESY_AUTH_TOKEN=

# Resy auto-book: set to 0 to open Chrome visibly for debugging (default: headless)
# RESY_BOOK_HEADLESS=0

# Optional: AI model (default: openai:gpt-4.1-mini)
# AI_MODEL=openai:gpt-4.1-mini

# Maxim AI (optional: tracing and evaluation)
# MAXIM_API_KEY=
# MAXIM_LOG_REPO_ID=
# MAXIM_DEBUG=false

# Mobile auth (dev): fixed 6-digit OTP for phone login; omit for random codes (logged on server)
# AUTH_OTP_FIXED=123456

# -----------------------------------------------------------------------------
# Discovery workload (.env is source of truth). Omit a var to use its default.
# -----------------------------------------------------------------------------
# DISCOVERY_DATE_TIMEZONE=America/New_York
# DISCOVERY_WINDOW_DAYS=7
# DISCOVERY_TIME_SLOTS=20:30
# DISCOVERY_PARTY_SIZES=2,4
# DISCOVERY_MAX_CONCURRENT_BUCKETS=8
# DISCOVERY_BUCKET_COOLDOWN_SECONDS=15
# DISCOVERY_TICK_SECONDS=2
# NOTIFIED_DEDUPE_MINUTES=30
# DISCOVERY_RESY_PER_PAGE=100
# DISCOVERY_RESY_MAX_PAGES=10
# DROP_EVENTS_RETENTION_DAYS=7
# NOTIFICATIONS_RETENTION_DAYS=30

# --- Multi-market: enable additional cities ---
# Comma-separated market slugs.  Defaults to "nyc" only.
# Add "miami" to scan Miami Beach + surrounding area concurrently.
# DISCOVERY_MARKETS=nyc,miami
#
# Optional: override bounding box per market (south_lat,west_lng,north_lat,east_lng)
# DISCOVERY_MARKET_NYC_BOX=40.691,-74.030,40.882,-73.910
# DISCOVERY_MARKET_MIAMI_BOX=25.700,-80.320,25.920,-80.115

# -----------------------------------------------------------------------------
# Push notifications (APNs) for new-drop alerts to iOS. Optional; omit to skip push.
# Apple Developer → Keys → key with APNs → download .p8 once. Key ID = filename AuthKey_<KEYID>.p8
# Team ID = Membership page. Do NOT commit the .p8 file (keep outside repo or use BASE64 in .env only).
# -----------------------------------------------------------------------------
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.dropfeed.app
# APNS_KEY_P8_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# Or: APNS_KEY_P8_BASE64=<base64 of entire .p8 file>  (no newlines in value)
# APNS_USE_SANDBOX=true